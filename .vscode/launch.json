{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug app (one click)",
      "type": "cppdbg",
      "request": "launch",

      "program": "${workspaceFolder}/build/app",
      "cwd": "${workspaceFolder}",

      "stopAtEntry": false,
      "externalConsole": false,

      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",

      "preLaunchTask": "Configure + Build (Debug)",

      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
